# --- Research APIs ---
OPENAI_API_KEY=sk-...
NEWSAPI_KEY=...
TAVILY_API_KEY=tvly-...

# Reddit (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=daily-audio-digest/1.0

# --- TTS ---
GOOGLE_AI_API_KEY=...
TTS_VOICE_A=Charon
TTS_VOICE_B=Kore

# --- Scriptwriter ---
SCRIPTWRITER_MODEL=gpt-4o
RESEARCH_BACKEND=auto

# --- Database ---
# SQLite (default):
# DATABASE_URL=sqlite:///data/digest.db
# PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/daily_audio_digest

# --- Paths (optional, defaults shown) ---
# AUDIO_DIR=data/audio
# DB_PATH=data/digest.db
